# Локальная разработка без Docker — скопируйте в .env
# При деплое через Docker используйте docker-compose.yml
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_server_id_for_command_registration

# Only this channel accepts /pp and /info (leave empty to allow all channels)
ALLOWED_CHANNEL_ID=your_channel_id_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Max attachment size in bytes (default 2 MB — saves tokens)
MAX_IMAGE_SIZE_BYTES=2097152

# Max image dimensions in pixels
MAX_IMAGE_WIDTH=1200
MAX_IMAGE_HEIGHT=1200

# Rate limit for /pp: max attempts per user per window
PP_RATE_LIMIT_MAX=2
PP_RATE_LIMIT_WINDOW_MS=600000
